{
	"name": "regional-site-menu",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "nuxt dev",
		"build": "NODE_OPTIONS=\"--max-old-space-size=8192\"  nuxt build",
		"postinstall": "nuxt prepare",
		"preview": "nuxt preview",
		"analyze": "nuxt analyze",
		"test:unit": "vitest run --project unit --project nuxt",
		"test:unit:watch": "vitest --project unit --project nuxt",
		"test:coverage": "vitest run --coverage --project unit --project nuxt",
		"nuxt:prepare": "nuxt prepare",
		"prepare": "husky || true && pnpm nuxt:prepare",
		"format:check": "prettier --check .",
		"format:fix": "prettier --write .",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"typecheck": "nuxi typecheck",
		"nuxt:upgrade": "pnpm dlx nuxt upgrade --dedupe"
	},
	"packageManager": "pnpm@10.32.1",
	"devDependencies": {
