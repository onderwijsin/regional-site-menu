#!/bin/bash

# Get list of staged files (Added, Copied, Modified) as NUL-delimited data
# so filenames with spaces are handled correctly.
STAGED_FILES_FILE="$(mktemp)"
trap 'rm -f "$STAGED_FILES_FILE"' EXIT
git diff --cached --name-only --diff-filter=ACM -z > "$STAGED_FILES_FILE"

# Run gitleaks to scan for secrets in staged files
# Disables user git config to prevent color codes from breaking gitleaks parsing
GIT_CONFIG_GLOBAL=/dev/null GIT_CONFIG_SYSTEM=/dev/null \
  gitleaks git --staged --config .gitleaks.toml --verbose --exit-code 1

# Load environment variables from .env file
if [ -f .env ]; then
    export $(grep -v '^#' .env | xargs)
fi

# Format
if [ "${DISABLE_PRE_COMMIT_FORMAT:-false}" != "true" ]; then
  pnpm format:fix

  # Re-add only previously staged files (if they still exist)
  xargs -0 -r git add -- < "$STAGED_FILES_FILE"
fi

# Lint
if [ "${DISABLE_PRE_COMMIT_LINT:-false}" != "true" ]; then
  pnpm lint:fix

  # Re-add only previously staged files (if they still exist)
  xargs -0 -r git add -- < "$STAGED_FILES_FILE"
fi
